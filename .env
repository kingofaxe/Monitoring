# ╔══════════════════════════════════════════════════════╗
# ║  MONITORING STACK — KONFIGURASI ENVIRONMENT         ║
# ║  Edit file ini sebelum deploy!                      ║
# ║  Lokasi di server: /opt/web/monitoring/.env         ║
# ╚══════════════════════════════════════════════════════╝

# ── Grafana ──────────────────────────────────────────
GRAFANA_PASSWORD=GantiDenganPasswordKuat123!
# Ganti localhost dengan IP server kamu saat di-deploy ke Linux
GRAFANA_ROOT_URL=http://localhost:8099/

# ── IP Target Monitoring ─────────────────────────────
# IP Proxmox host (install node_exporter di sana)
IP_PROXMOX=10.5.0.10

# IP VM Immich (install node_exporter di sana)
IP_IMMICH=10.5.0.101

# IP MikroTik (SNMP harus aktif)
IP_MIKROTIK=10.5.0.1

# IP Unifi Controller (SNMP harus aktif)
IP_UNIFI=10.5.0.2

# ── SNMP Community String ────────────────────────────
SNMP_COMMUNITY_MIKROTIK=public
SNMP_COMMUNITY_UNIFI=public
